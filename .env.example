NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Public client key: use legacy anon JWT, OR new publishable key — not both in production.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only: Admin user invites (never commit real value)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: apply SQL migrations from CLI (npm run db:apply). API keys alone cannot run DDL.
# Use Database password from Supabase → Project Settings → Database (not the anon/service JWT).
# DATABASE_URL=postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# SUPABASE_DB_PASSWORD=PASSWORD

# Optional Upstash Redis cache. The app falls back to in-process memory if these are blank.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_CACHE_PREFIX=aura
